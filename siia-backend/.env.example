# SIIA 2.0 - Backend environment template
# Copy this file to .env and adjust values for your environment.

# ----------------------------------------------------------------------------
# Base
# ----------------------------------------------------------------------------
USE_LDAP_AUTH=false
LDAP_SERVER_URI=
LDAP_BIND_DN_TEMPLATE=
LDAP_USE_SSL=false

# django-auth-ldap (enabled when USE_LDAP_AUTH=true)
AUTH_LDAP_SERVER_URI=
AUTH_LDAP_BIND_DN=
AUTH_LDAP_BIND_PASSWORD=
AUTH_LDAP_USER_SEARCH_BASE=
AUTH_LDAP_USER_SEARCH_FILTER=(sAMAccountName=%(user)s)

# ----------------------------------------------------------------------------
# CMS menu URL validation by environment
# ----------------------------------------------------------------------------
# Allowed values: dev | hml | prod
SIIA_ENV=dev

# Legacy hosts (defaults by SIIA_ENV if not provided)
# dev  -> siia-dev.eb.mil.br
# hml  -> siia-hom.eb.mil.br
# prod -> siia.eb.mil.br
# Optional override (comma-separated):
# CMS_ALLOWED_LEGACY_HOSTS=siia-dev.eb.mil.br,legados-dev.eb.mil.br

# Nextcloud hosts (recommended explicit list in each environment)
CMS_ALLOWED_NEXTCLOUD_HOSTS=nextcloud.aman.eb.mil.br,nextcloud.exemplo.gov.br

# Optional external hosts (comma-separated)
CMS_ALLOWED_EXTERNAL_HOSTS=


# ----------------------------------------------------------------------------
# Suggested blocks per environment
# ----------------------------------------------------------------------------

# [DEV]
# SIIA_ENV=dev
# CMS_ALLOWED_LEGACY_HOSTS=siia-dev.eb.mil.br
# CMS_ALLOWED_NEXTCLOUD_HOSTS=nextcloud-dev.eb.mil.br
# CMS_ALLOWED_EXTERNAL_HOSTS=www.gov.br,portal.gov.br

# [HML]
# SIIA_ENV=hml
# CMS_ALLOWED_LEGACY_HOSTS=siia-hom.eb.mil.br
# CMS_ALLOWED_NEXTCLOUD_HOSTS=nextcloud-hml.eb.mil.br
# CMS_ALLOWED_EXTERNAL_HOSTS=www.gov.br,portal.gov.br

# [PROD]
# SIIA_ENV=prod
# CMS_ALLOWED_LEGACY_HOSTS=siia.eb.mil.br
# CMS_ALLOWED_NEXTCLOUD_HOSTS=nextcloud.aman.eb.mil.br
# CMS_ALLOWED_EXTERNAL_HOSTS=www.gov.br,portal.gov.br
